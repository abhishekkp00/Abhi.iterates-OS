# ═══════════════════════════════════════════════════════════════════════════════
# .env.example — AbhiIterates.OS Environment Variable Template
# Copy this file to .env and fill in your own values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/your_db_name
SPRING_DATASOURCE_USERNAME=your_db_user
SPRING_DATASOURCE_PASSWORD=your_db_password

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8095
CORS_ALLOWED_ORIGINS=http://localhost:5180

# ── Security: JWT ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=replace_with_a_strong_random_secret_at_least_64_chars

# ── Admin Seed Account ────────────────────────────────────────────────────────
# These credentials are used ONLY at first startup to seed the admin user.
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=YourStrongP@ssword123

# ── Google OAuth2 ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── AI (OpenAI / Groq compatible) ─────────────────────────────────────────────
OPENAI_BASE_URL=https://api.groq.com/openai
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=llama-3.3-70b-versatile

# ── UPI Payments ──────────────────────────────────────────────────────────────
UPI_ID=yourname@upi

# ── Cloudinary Storage ────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

