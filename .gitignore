# =============================================================================
# AbhiIterates.OS — Combined .gitignore
# Covers: Node.js / React, Java / Spring Boot, Python / FastAPI
# =============================================================================

# -----------------------------------------------------------------------------
# Environment Variables — NEVER commit secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# Node.js / Frontend (React + Vite)
# -----------------------------------------------------------------------------
node_modules/
dist/
dist-ssr/
build/
.vite/
*.local
.cache/
.eslintcache
.stylelintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
package-lock.json
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Java / Spring Boot Backend
# -----------------------------------------------------------------------------
target/
*.class
*.jar
*.war
*.ear
*.nar
*.zip
*.tar.gz
*.rar
.mvn/wrapper/maven-wrapper.jar
hs_err_pid*
replay_pid*
.factorypath
spring-shell.log

# IDE — IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr
out/

# IDE — Eclipse
.project
.classpath
.c9/
*.launch
.settings/
*.bak

# IDE — VS Code (keep settings, ignore workspace)
.vscode/settings.json
.vscode/tasks.json
.vscode/launch.json
.vscode/extensions.json
*.vscodeignore
!.vscode/extensions.json.recommended

# -----------------------------------------------------------------------------
# Python / AI Service (FastAPI + LangChain)
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
ENV/
.env/
pip-log.txt
pip-delete-this-directory.txt
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
dist/
downloads/
eggs/
.eggs/
/lib/
/lib64/
parts/
sdist/
var/
wheels/
*.dist-info/
*.pyo

# Jupyter Notebooks
.ipynb_checkpoints
*.ipynb

# AI / ML artifacts — large files belong in object storage, not git
*.pkl
*.pt
*.bin
*.safetensors
*.gguf
faiss_index/
chroma_db/
vector_store/
models/

# -----------------------------------------------------------------------------
# macOS
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# -----------------------------------------------------------------------------
# Linux
# -----------------------------------------------------------------------------
*~

# -----------------------------------------------------------------------------
# Windows
# -----------------------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
*.log
logs/

# -----------------------------------------------------------------------------
# Test Reports & Coverage
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
test-results/

# Uploaded Files & Temporary Classpath
classpath.txt
uploads/*
!uploads/.gitkeep
backend/uploads/*
!backend/uploads/.gitkeep
**/uploads/*

